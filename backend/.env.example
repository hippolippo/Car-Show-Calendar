# T011: Backend Environment Template

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://caruser:carpass123@localhost:5432/car_calendar

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
JWT_COOKIE_MAX_AGE=604800000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# File Upload Configuration (local filesystem for MVP)
UPLOAD_DIR=./uploads/fliers
MAX_FILE_SIZE=10485760

# Cloudflare R2 (Optional - for future use)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=car-calendar
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
